
service BotManagementInteraction(spaceId: guid)
{
    SearchBots(query: string): BotSearchResult[];
    GetBotDetails(botAppId: guid): BotDetails;
    GetInstalledBots(): InstalledBotInfo[];
    InstallBot(botAppId: guid): InstallBotResult;
    UninstallBot(botAppId: guid): UninstallBotResult;
    GetSpaceCommands(): SpaceCommand[];
    ApproveBotEntitlements(botAppId: guid): ApproveBotEntitlementsResult;
}

msg BotSearchResult {
    appId: guid;
    name: string;
    username: string;
    description: string?;
    avatarFileId: string?;
    isVerified: bool;
    requiredScopes: string[];
    requiredEntitlements: ArgonEntitlement;
}

msg BotDetails {
    appId: guid;
    name: string;
    username: string;
    description: string?;
    avatarFileId: string?;
    isVerified: bool;
    isPublic: bool;
    requiredScopes: string[];
    maxSpaces: i4;
    teamName: string;
    requiredEntitlements: ArgonEntitlement;
}

msg InstalledBotInfo {
    appId: guid;
    name: string;
    username: string;
    avatarFileId: string?;
    isVerified: bool;
    botUserId: guid;
    requiredEntitlements: ArgonEntitlement;
    grantedEntitlements: ArgonEntitlement;
    pendingApproval: bool;
}

union InstallBotResult {
    SuccessInstallBot(bot: InstalledBotInfo),
    FailedInstallBot(error: InstallBotError)
}

enum InstallBotError {
    NONE,
    NOT_FOUND,
    ALREADY_INSTALLED,
    INSUFFICIENT_PERMISSIONS,
    BOT_SPACE_LIMIT,
    BOT_RESTRICTED
}

union UninstallBotResult {
    SuccessUninstallBot(),
    FailedUninstallBot(error: UninstallBotError)
}

enum UninstallBotError {
    NONE,
    NOT_FOUND,
    NOT_INSTALLED,
    INSUFFICIENT_PERMISSIONS
}

union ApproveBotEntitlementsResult {
    SuccessApproval(),
    FailedApproval(error: ApproveBotEntitlementsError)
}

enum ApproveBotEntitlementsError {
    NONE,
    NOT_FOUND,
    NOT_INSTALLED,
    INSUFFICIENT_PERMISSIONS,
    ALREADY_UP_TO_DATE
}

enum CommandOptionType: u2 {
    String,
    Integer,
    Boolean,
    User,
    Channel,
    Role,
    Number
}

msg SpaceCommandOption {
    name: string;
    description: string;
    type: CommandOptionType;
    required: bool;
}

msg SpaceCommand {
    commandId: guid;
    appId: guid;
    name: string;
    description: string;
    options: SpaceCommandOption[];
}
