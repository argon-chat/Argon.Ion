{
    "name": "ArgonContracts",
    "features": [
        "orleans",
        "std"
    ],
    "generators": {
        "dotnet": {
            "features": [
                "server",
                "client",
                "models"
            ],
            "outputs": "./../Argon.CodeGen"
        },
        "browser": {
            "outputFile": "./../packages/glue/src/argonChat.ts"
        },
        "rust": {
            "features": [
                "client",
                "models"
            ],
            "outputs": "./../../src/argon-contracts/src/generated",
            "crateName": "argon-contracts",
            "rustcorePath": null
        }
    }
}   