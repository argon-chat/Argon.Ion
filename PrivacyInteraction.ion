enum PrivacyRuleMode: u2 {
    EVERYBODY,
    CONTACTS,
    NOBODY
}

msg PrivacyRuleView {
    key: string;
    mode: PrivacyRuleMode;
    scopeSpaceId: guid?;
    allow: guid[];
    deny: guid[];
}

service PrivacyInteraction() {
    GetPrivacyRule(key: string, spaceId: guid?): PrivacyRuleView;
    SetPrivacyRule(key: string, mode: PrivacyRuleMode, spaceId: guid?, allow: guid[], deny: guid[]): bool;
}
