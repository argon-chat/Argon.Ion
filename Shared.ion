attribute @AllowAnonymous();
attribute @MachineIdOptional();
attribute @DoNotRequireSessionContext();

enum ArgonAuthMode {
    EmailPassword,
    EmailOtp,
    EmailPasswordOtp,
    PasskeyOnly,
    PasskeyWithOtp
}

enum OtpMethod {
    Email,
    Phone,
    Totp
}

msg ArgonIonTicket {
    userId: guid;
    ip: string;
    ray: string;
    clientName: string;
    hostName: string;
    appId: string;
    sessionId: guid;
    machineId: string;
    region: string;
}
